{
  "name": "@mfe/utils",
  "version": "0.0.1",
  "description": "Shared utility functions",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "dependencies": {
    "@mfe/types": "workspace:*",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nx/vite": "^22.6.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.13.9",
    "autoprefixer": "^10.4.27",
    "nx": "22.6.4",
    "postcss": "^8.5.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "~4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "//": "주석: 이 패키지는 로직 유틸리티를 제공하며, 빌드된 결과물을 통해 다른 앱이나 라이브러리에서 참조 가능합니다. pnpm workspace 프로토콜('workspace:*')을 사용하여 모노레포 내 최신 소스를 유지합니다."
}
