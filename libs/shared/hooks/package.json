{
  "name": "@mfe/hooks",
  "version": "0.0.1",
  "description": "Shared React hooks",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@mfe/types": "workspace:*",
    "jotai": "^2.19.1",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@nx/vite": "^22.6.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^22.13.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "autoprefixer": "^10.4.27",
    "nx": "22.6.4",
    "postcss": "^8.5.8",
    "typescript": "^6.0.2",
    "vite": "^8.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "~4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "//": "주석: 이 패키지는 React Hooks을 정의하며, 'peerDependencies'를 통해 앱의 React 버전을 사용하도록 설정되었습니다. pnpm workspace를 통한 로컬 개발을 지원합니다."
}
