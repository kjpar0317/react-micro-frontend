{
  "name": "@shared/types",
  "version": "0.0.1",
  "description": "Shared TypeScript types and interfaces",
  "private": false,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "nx build types",
    "test": "nx test types"
  },
  "dependencies": {
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@types/node": "20.19.9",
    "nx": "22.6.4",
    "typescript": "^6.0.2",
    "vitest": "~4.1.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "//": "주석: 이 패키지는 공유 타입을 정의하며, npm에 배포 가능한 독립적인 구성을 가집니다. pnpm workspace를 통해 로컬 네트워크 내에서 'workspace:*' 프로토콜로 참조될 수 있습니다."
}
