{
  "name": "remote-billing",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/remote-billing/src",
  "projectType": "application",
  "tags": [],
  "// targets": "to see all targets run: nx show project remote-billing --web",
  "targets": {
    "build": {
      "executor": "@nx/vite:build",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/apps/remote-billing",
        "configFile": "apps/remote-billing/vite.config.mts"
      }
    },
    "serve": {
      "executor": "@nx/vite:dev-server",
      "options": {
        "buildTarget": "remote-billing:build",
        "port": 4201,
        "configFile": "apps/remote-billing/vite.config.mts"
      }
    },
    "preview-server": {
      "executor": "@nx/vite:preview-server",
      "options": {
        "buildTarget": "remote-billing:build",
        "staticFilePath": "dist/apps/remote-billing",
        "configFile": "apps/remote-billing/vite.config.mts"
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{options.reportsDirectory}"],
      "options": {
        "reportsDirectory": "../../coverage/apps/remote-billing",
        "configFile": "apps/remote-billing/vite.config.mts"
      }
    }
  }
}
